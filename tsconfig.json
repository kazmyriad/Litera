// this config is read by vite (client-side)

{
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["vite/client", "node"],
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "forceConsistentCasingInFileNames": true
    
  },
  "include": ["src/**/*.ts", "vite.config.*", "src/components/NavBar.js", "src/App.tsx"],
  "exclude": ["dist", "server.ts", "imagekit.ts", "dist-server", "node_modules"]
}

